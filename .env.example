# ── Site Khata — environment template ───────────────────────────────────────
# Isko copy karke `.env` banao aur real values bharo:
#   cp .env.example .env   (Windows: copy .env.example .env)
# `.env` git me commit NAHI hoti; ye template commit hoti hai.

# Flask session signing key (zaroori). Generate:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# Pehli baar app chalne par is email/password se default ADMIN user banta hai
# (sirf tab jab database me koi user na ho). Login karke password zaroor badlo!
# Baaki sab users invite email se khud apna password set karte hain (neeche
# SMTP config zaroori hai warna invite link sirf server console par print hogi).
ADMIN_EMAIL=admin@sitekhata.local
ADMIN_PASSWORD=admin123

# ── Invite / password-reset emails (Gmail SMTP) ─────────────────────────────
# Google Account > Security > 2-Step Verification on karo, phir App Passwords
# se 16-character app password banao (normal Gmail password kaam nahi karega).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# SMTP_FROM=  (khali chodo to SMTP_USER hi "From" address ban jaata hai)

# Invite link isi base URL se banti hai (production me apna domain daalo)
APP_BASE_URL=http://localhost:5000

# PostgreSQL connection URL. Khali/comment = SQLite fallback.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (default 5000)
PORT=5000
